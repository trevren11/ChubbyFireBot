# =============================================================================
# ChubbyFireBot Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Reddit API
# -----------------------------------------------------------------------------
# Create a Reddit app at: https://www.reddit.com/prefs/apps
# Select "script" type for personal use bots

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=ChubbyFireBot
REDDIT_PASSWORD=
REDDIT_USER_AGENT=ChubbyFireBot/1.0 by u/ChubbyFireBot

# -----------------------------------------------------------------------------
# Discord Bot
# -----------------------------------------------------------------------------
# Create a Discord app at: https://discord.com/developers/applications
# 1. Create application
# 2. Go to Bot section, create bot, copy token
# 3. Enable "Message Content Intent" under Privileged Gateway Intents
# 4. Invite bot with: https://discord.com/api/oauth2/authorize?client_id=1519741720206512168&permissions=2048&scope=bot

DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_APPLICATION_ID=1519741720206512168
DISCORD_PUBLIC_KEY=99b0ea556ebf87fe8d5a117a9e224a6d1c8ae638903fb8f99952a7d7912319b1

# -----------------------------------------------------------------------------
# Configuration
# -----------------------------------------------------------------------------

# Subreddit to moderate (without r/ prefix)
SUBREDDIT=chubbyfire

# Dry run mode - set to true to test without taking actions
DRY_RUN=false

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
